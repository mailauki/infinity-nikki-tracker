# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (one-time premium purchase)
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Create a product + one-time price in Stripe dashboard, paste the price ID here
STRIPE_PRICE_ID=price_...
# Get this after creating a webhook endpoint pointing to /api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: used to build absolute URLs in checkout redirects
NEXT_PUBLIC_SITE_URL=https://your-domain.com
